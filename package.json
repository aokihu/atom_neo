{
  "name": "atom-neo",
  "private": true,
  "workspaces": [
    "src/packages/shared",
    "src/packages/core",
    "src/packages/gateway",
    "src/packages/tui"
  ],
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "dev:all": "bun run --workspaces dev",
    "docs": "bun run --watch docs/server.tsx",
    "docs:dev": "bun run docs/server.tsx",
    "test": "bun test",
    "typecheck": "bun run --workspaces typecheck",
    "build": "bun run --workspaces build"
  },
  "dependencies": {
    "@atom-neo/shared": "workspace:*",
    "@atom-neo/core": "workspace:*",
    "@heroui/react": "^3.0.5",
    "@heroui/styles": "^3.0.5",
    "highlight.js": "^11.11.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "zod": "^3.24"
  }
}
