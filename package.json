{
  "name": "atom-neo",
  "version": "0.8.0",
  "workspaces": [
    "src/packages/shared",
    "src/packages/core",
    "src/packages/gateway",
    "src/packages/tui"
  ],
  "scripts": {
    "dev": "bun run src/main.ts --sandbox ./sandbox --log=pipe --log-level=debug --log-pipepath=/tmp/atom-debug",
    "dev:core": "bun run src/main.ts --mode core --port 3100 --sandbox ./sandbox",
    "docs": "bun run --watch docs/server.tsx",
    "docs:dev": "bun run docs/server.tsx",
    "test": "bun test",
    "typecheck": "bun run --workspaces typecheck",
    "build": "bun run --workspaces build",
    "build:bin": "mkdir -p dist && bun build ./src/main.ts --compile --outfile dist/atom --target bun"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.35",
    "@atom-neo/core": "workspace:*",
    "@atom-neo/shared": "workspace:*",
    "@atom-neo/tui": "workspace:*",
    "@heroui/react": "^3.0.5",
    "@heroui/styles": "^3.0.5",
    "@opentui/core": "^0.2.15",
    "@opentui/react": "^0.2.15",
    "ai": "^6.0.191",
    "highlight.js": "^11.11.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "zod": "^3.24"
  }
}
