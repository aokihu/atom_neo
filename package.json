{
  "name": "atom-neo",
  "version": "0.5.3",
  "workspaces": [
    "src/packages/shared",
    "src/packages/core",
    "src/packages/gateway",
    "src/packages/tui"
  ],
  "scripts": {
    "dev": "bun run src/main.ts --port 3100 --sandbox ./sandbox --log-file ./sandbox/logs/core.log & sleep 2 && bun run src/packages/tui/src/app.tsx -u http://127.0.0.1:3100; kill %1 2>/dev/null",
    "dev:core": "bun run --filter @atom-neo/core dev",
    "dev:all": "bun run --workspaces dev",
    "dev:tui": "bun run src/main.ts --port 3100 --sandbox ./sandbox & sleep 2 && bun run src/packages/tui/src/app.tsx -u http://127.0.0.1:3100; kill %1 2>/dev/null",
    "docs": "bun run --watch docs/server.tsx",
    "docs:dev": "bun run docs/server.tsx",
    "test": "bun test",
    "typecheck": "bun run --workspaces typecheck",
    "build": "bun run --workspaces build"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.35",
    "@atom-neo/core": "workspace:*",
    "@atom-neo/shared": "workspace:*",
    "@heroui/react": "^3.0.5",
    "@heroui/styles": "^3.0.5",
    "ai": "^6.0.191",
    "highlight.js": "^11.11.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "zod": "^3.24"
  }
}
