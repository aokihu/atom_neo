{
  "name": "atom-neo",
  "version": "1.6.0",
  "workspaces": [
    "src/packages/shared",
    "src/packages/core",
    "src/packages/setup-wizard",
    "src/packages/gateway",
    "src/packages/tui"
  ],
  "scripts": {
    "dev": "bun run src/main.ts --sandbox ./sandbox --log=file --log-level=debug --log-file=/tmp/atom-log-$(date +%s).log",
    "dev:core": "bun run src/main.ts --mode core --port 3100 --sandbox ./sandbox",
    "docs": "bun run --watch docs/server.tsx",
    "docs:dev": "bun run docs/server.tsx",
    "test": "bun test",
    "typecheck": "bun run --workspaces typecheck",
    "build": "bun run --workspaces build",
    "build:bin": "mkdir -p dist && bun -e 'const{writeFileSync}=require(\"fs\");const pkg=require(\"./package.json\");writeFileSync(\"src/version.ts\",`export const VERSION = \\\"${pkg.version}\\\";\\n`)' && bun build ./src/main.ts --compile --outfile dist/atom --target bun"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.38",
    "@ai-sdk/mcp": "^1.0.52",
    "@atom-neo/core": "workspace:*",
    "@atom-neo/setup-wizard": "workspace:*",
    "@atom-neo/shared": "workspace:*",
    "@atom-neo/tui": "workspace:*",
    "@heroui/react": "^3.2.0",
    "@heroui/styles": "^3.2.0",
    "@opentui/core": "^0.4.1",
    "@opentui/react": "^0.4.1",
    "ai": "^6.0.206",
    "highlight.js": "^11.11.1",
    "opentui-spinner": "^0.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
