{
  "version": 2,
  "theme": "dark",
  "providerProfiles": {
    "advanced": "deepseek/deepseek-v4-flash",
    "balanced": "deepseek/deepseek-v4-flash",
    "basic": "deepseek/deepseek-v4-flash"
  },
  "providers": {
    "deepseek": {
      "apiKeyEnv": "DEEPSEEK_API_KEY",
      "models": ["deepseek-v4-flash"],
      "thinking": "disabled",
      "contextLimit": 131072
    }
  },
  "transport": {
    "maxOutputTokens": 4096
  },
  "gateway": {
    "jwtSecret": "change-me-minimum-16-chars",
    "port": 3000
  },
  "tui": {
    "theme": "github-dark"
  },
  "permission": {
    "whitelist": []
  },
  "log": {
    "level": "debug",
    "ignore": []
  },
  "conversation": {
    "maxSteps": 20,
    "maxChainDepth": 5
  }
}